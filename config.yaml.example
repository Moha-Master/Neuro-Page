discord:
  token: "YOUR_DISCORD_BOT_TOKEN_HERE"  # Get from https://discord.com/developers/applications
  channel_id: 1234567890123456789  # Replace with actual Discord channel ID

server:
  host: "0.0.0.0"
  port: 8000

updater:
  cron: "single"  # Options: "single" (run once), or standard 5-field cron: "*/15 * * * *" (every 15 min), "0 * * * *" (every hour), "0 3 * * *" (daily at 3am)
  proxy:
    enabled: false  # Set to true to use proxy for all requests (Discord + HTTP)
    address: "socks5://127.0.0.1:7890"  # Supports socks5://, http://, https://
